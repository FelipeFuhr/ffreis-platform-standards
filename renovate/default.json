{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "schedule": ["before 6am on Monday"],
  "prConcurrentLimit": 5,
  "prHourlyLimit": 2,
  "packageRules": [
    {
      "matchUpdateTypes": ["major"],
      "labels": ["dependencies", "major-update"],
      "automerge": false
    },
    {
      "matchManagers": ["github-actions"],
      "groupName": "GitHub Actions",
      "labels": ["dependencies"],
      "matchUpdateTypes": ["minor", "patch", "digest"],
      "automerge": true,
      "automergeType": "pr"
    },
    {
      "matchDepNames": ["FelipeFuhr/ffreis-platform-standards"],
      "groupName": "platform-standards SHA pins",
      "labels": ["dependencies"],
      "matchUpdateTypes": ["minor", "patch", "digest"],
      "automerge": true,
      "automergeType": "pr"
    },
    {
      "matchDepNames": ["FelipeFuhr/ffreis-platform-ci-local"],
      "groupName": "ci-local harness pin",
      "labels": ["dependencies"],
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true,
      "automergeType": "pr"
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "fileMatch": ["(^|/)Makefile(\\.jinja)?$", "(^|/)lefthook\\.yml$"],
      "matchStrings": [
        "PLATFORM_STANDARDS_SHA\\s*[?:]?=\\s*(?<currentDigest>[a-f0-9]{40})\\s*#\\s*(?<currentValue>v\\d+\\.\\d+\\.\\d+)",
        "git_url:\\s*https://github\\.com/FelipeFuhr/ffreis-platform-standards\\s*\\n\\s*ref:\\s*(?<currentDigest>[a-f0-9]{40})\\s*#\\s*(?<currentValue>v\\d+\\.\\d+\\.\\d+)"
      ],
      "depNameTemplate": "FelipeFuhr/ffreis-platform-standards",
      "datasourceTemplate": "github-tags"
    },
    {
      "customType": "regex",
      "fileMatch": ["(^|/)Makefile(\\.jinja)?$"],
      "matchStrings": [
        "ffreis-platform-ci-local/(?<currentValue>v\\d+\\.\\d+\\.\\d+)/scripts/run-ci-local\\.sh",
        "CI_LOCAL_FINDINGS_REF=(?<currentValue>v\\d+\\.\\d+\\.\\d+)"
      ],
      "depNameTemplate": "FelipeFuhr/ffreis-platform-ci-local",
      "datasourceTemplate": "github-tags"
    }
  ]
}
