{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["github>FelipeFuhr/ffreis-platform-standards:renovate/default"],
  "enabledManagers": ["gomod", "dockerfile", "github-actions"],
  "packageRules": [
    { "matchManagers": ["gomod"],      "groupName": "Go dependencies",    "labels": ["dependencies"] },
    { "matchManagers": ["dockerfile"], "groupName": "Docker base images", "labels": ["dependencies"] }
  ]
}
