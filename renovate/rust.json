{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["github>FelipeFuhr/ffreis-platform-standards:renovate/default"],
  "enabledManagers": ["cargo", "dockerfile", "github-actions"],
  "packageRules": [
    { "matchManagers": ["cargo"],      "groupName": "Rust dependencies",  "labels": ["dependencies"] },
    { "matchManagers": ["dockerfile"], "groupName": "Docker base images", "labels": ["dependencies"] }
  ]
}
