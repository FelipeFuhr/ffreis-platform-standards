# Extra secrets for run-ci-local.sh
# Copy this file to ~/.config/ffreis/ci-local.env (NOT to a repo — it's secrets).
# Format: KEY=VALUE per line. Blank lines and `#` comments allowed.
#
# Only fill in secrets you actually have locally. The script passes whatever
# is set; jobs that need a missing secret will be flagged as
# "credential-missing" in the summary banner, not as real failures.
#
# AWS creds and GITHUB_TOKEN are auto-detected from your environment / gh CLI —
# do NOT duplicate them here.

# Example secrets used by the fleet:
# RECAPTCHA_SECRET_KEY=
# SUBSTACK_API_KEY=
# SONAR_TOKEN=
# CODECOV_TOKEN=
# RELEASE_PLEASE_TOKEN=
# CI_REPO_READ_TOKEN=
# CI_DISPATCH_TOKEN=
